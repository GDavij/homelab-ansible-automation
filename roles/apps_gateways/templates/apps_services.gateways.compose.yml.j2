services:
  memos:
    image: neosmemo/memos:{{ memos_version }}
    container_name: memos
    restart: unless-stopped
    networks:
      - proxy_net
    volumes:
      - /opt/apps/memos:/var/opt/memos

  memos-sidecar:
    image: ghostunnel/ghostunnel:{{ ghostunnel_version }}
    container_name: memos-sidecar
    restart: unless-stopped
    network_mode: service:memos
    command:
      - "server"
      - "--listen=0.0.0.0:8443"
      - "--target=127.0.0.1:5230"
      - "--cert=/certs/memos.crt"
      - "--key=/certs/memos.key"
      - "--cacert=/certs/ca.crt"
      - "--allow-cn=gateway.lab"
    volumes:
      - /etc/pki/homelab/certs/memos.crt:/certs/memos.crt:ro
      - /etc/pki/homelab/private/memos.key:/certs/memos.key:ro
      - /etc/pki/homelab/certs/root-ca.crt:/certs/ca.crt:ro
    user: "65534:65534"
    depends_on:
      - memos
    healthcheck:
      test: ["CMD", "nc", "-z", "127.0.0.1", "8443"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  sure-finance-db:
    image: postgres:{{ postgres_version }}
    container_name: sure-finance-db
    restart: unless-stopped
    networks:
      - proxy_net
    volumes:
      - /opt/apps/sure/postgres:/var/lib/postgresql/data
    environment:
      - POSTGRES_USER={{ sure_finance.postgres.user }}
      - POSTGRES_PASSWORD={{ sure_finance.postgres.password }}
      - POSTGRES_DB={{ sure_finance.postgres.db }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ sure_finance.postgres.user }} -d {{ sure_finance.postgres.db }}"]
      interval: 5s
      timeout: 5s
      retries: 5
      start_period: 30s

  sure-finance-redis:
    image: redis:{{ redis_version }}
    container_name: sure-finance-redis
    restart: unless-stopped
    networks:
      - proxy_net
    volumes:
      - /opt/apps/sure/redis:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5

  sure-finance:
    image: ghcr.io/we-promise/sure:{{ sure_finance_version }}
    container_name: sure-finance
    restart: unless-stopped
    networks:
      - proxy_net
    volumes:
      - /opt/apps/sure/storage:/rails/storage
    environment:
      - SECRET_KEY_BASE={{ sure_finance.system.secret_key_base }}
      - SELF_HOSTED=true
      - RAILS_FORCE_SSL=false
      - RAILS_ASSUME_SSL=false
      - DB_HOST=sure-finance-db
      - DB_PORT=5432
      - POSTGRES_DB={{ sure_finance.postgres.db }}
      - POSTGRES_USER={{ sure_finance.postgres.user }}
      - POSTGRES_PASSWORD={{ sure_finance.postgres.password }}
      - REDIS_URL=redis://sure-finance-redis:6379/1
    depends_on:
      sure-finance-db:
        condition: service_healthy
      sure-finance-redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:3000/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

  sure-finance-worker:
    image: ghcr.io/we-promise/sure:{{ sure_finance_version }}
    container_name: sure-finance-worker
    restart: unless-stopped
    command: bundle exec sidekiq
    networks:
      - proxy_net
    volumes:
      - /opt/apps/sure/storage:/rails/storage
    environment:
      - SECRET_KEY_BASE={{ sure_finance.system.secret_key_base }}
      - SELF_HOSTED=true
      - RAILS_FORCE_SSL=false
      - RAILS_ASSUME_SSL=false
      - DB_HOST=sure-finance-db
      - DB_PORT=5432
      - POSTGRES_DB={{ sure_finance.postgres.db }}
      - POSTGRES_USER={{ sure_finance.postgres.user }}
      - POSTGRES_PASSWORD={{ sure_finance.postgres.password }}
      - REDIS_URL=redis://sure-finance-redis:6379/1
    depends_on:
      sure-finance-db:
        condition: service_healthy
      sure-finance-redis:
        condition: service_healthy

  sure-finance-sidecar:
    image: ghostunnel/ghostunnel:{{ ghostunnel_version }}
    container_name: sure-finance-sidecar
    restart: unless-stopped
    network_mode: service:sure-finance
    command:
      - "server"
      - "--listen=0.0.0.0:8443"
      - "--target=127.0.0.1:3000"
      - "--cert=/certs/sure-finance.crt"
      - "--key=/certs/sure-finance.key"
      - "--cacert=/certs/ca.crt"
      - "--allow-cn=gateway.lab"
    volumes:
      - /etc/pki/homelab/certs/sure-finance.crt:/certs/sure-finance.crt:ro
      - /etc/pki/homelab/private/sure-finance.key:/certs/sure-finance.key:ro
      - /etc/pki/homelab/certs/root-ca.crt:/certs/ca.crt:ro
    user: "65534:65534"
    depends_on:
      - sure-finance
    healthcheck:
      test: ["CMD", "nc", "-z", "127.0.0.1", "8443"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  trilium:
    image: triliumnext/trilium:{{ trilium_version }}
    container_name: trilium
    restart: unless-stopped
    networks:
      - proxy_net
    volumes:
      - /opt/apps/trilium:/home/node/trilium-data
    environment:
      - TRILIUM_NETWORK_HOST=0.0.0.0
      - TRILIUM_NETWORK_PORT=8080

  trilium-sidecar:
    image: ghostunnel/ghostunnel:{{ ghostunnel_version }}
    container_name: trilium-sidecar
    restart: unless-stopped
    network_mode: service:trilium
    command:
      - "server"
      - "--listen=0.0.0.0:8443"
      - "--target=127.0.0.1:8080"
      - "--cert=/certs/trilium.crt"
      - "--key=/certs/trilium.key"
      - "--cacert=/certs/ca.crt"
      - "--allow-cn=gateway.lab"
    volumes:
      - /etc/pki/homelab/certs/trilium.crt:/certs/trilium.crt:ro
      - /etc/pki/homelab/private/trilium.key:/certs/trilium.key:ro
      - /etc/pki/homelab/certs/root-ca.crt:/certs/ca.crt:ro
    user: "65534:65534"
    depends_on:
      - trilium
    healthcheck:
      test: ["CMD", "nc", "-z", "127.0.0.1", "8443"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

networks:
  proxy_net:
    external: true
