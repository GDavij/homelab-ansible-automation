---
# Copy this file to secrets.vault.yml and fill in real values
# Then encrypt: ansible-vault encrypt group_vars/Workstations/secrets.vault.yml
#
# Initialize Vault:
#   kubectl exec -n security <vault-pod> -- vault operator init -key-shares=1 -key-threshold=1 -format=json
# Unseal:
#   kubectl exec -n security <vault-pod> -- vault operator unseal <unseal_key>
# Create ESO token:
#   kubectl exec -n security <vault-pod> -- vault login <root_token>
#   kubectl exec -n security <vault-pod> -- vault policy write eso-reader - <<< 'path "secret/data/*" { capabilities = ["read"] }'
#   kubectl exec -n security <vault-pod> -- vault token create -policy=eso-reader -period=768h -format=json

vault_unseal_key: "CHANGEME"
vault_root_token: "hvs.CHANGEME"
vault_eso_token: "hvs.CHANGEME"
